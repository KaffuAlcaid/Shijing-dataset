[
  {
    "id": "shijing_guofeng_zhounan_hanguang_s001",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "汉广",
      "序号": 1
    },
    "校勘文": "南有乔木，不可休息。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "南有乔木，不可休息",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "南方之木，美乔上竦也。"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_hanguang_s002",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "汉广",
      "序号": 2
    },
    "校勘文": "汉有游女，不可求思。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "汉有游女不可求思",
        "粒度": "句",
        "注释类型": "训诂",
        "内容": "兴也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "思",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "思，辞也。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "游女",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "汉上游女",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "汉有游女不可求思",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "汉上游女，无求思者。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "不可",
        "粒度": "词",
        "注释类型": "笺注",
        "内容": "不可者，本有可道也。",
        "文献id": "src001"
      },
      {
        "id": "n006",
        "anchor": "汉有游女不可求思",
        "粒度": "句",
        "注释类型": "笺注",
        "内容": "兴者，喻贤女虽出游流水之上，人无欲求犯礼者，亦由贞洁使之然。",
        "文献id": "src001"
      },
      {
        "id": "n007",
        "anchor": "汉",
        "粒度": "字",
        "注释类型": "校勘",
        "内容": "「流水」，本或作「汉水」。",
        "文献id": "src001"
      }
    ]
  },
