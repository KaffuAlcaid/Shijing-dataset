        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "马",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "六尺以上曰马。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "之子",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "之子，是子也。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "之子于归言秣其马",
        "粒度": "句",
        "注释类型": "笺注",
        "内容": "谦不敢斥其适己，于是子之嫁，我原秣其马，致礼饩，示有意焉。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "秣",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "秣，莫葛反。",
        "文献id": "src001"
      }
    ]
  },
