  {
    "id": "shijing_guofeng_zhounan_hanguang_s005",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "汉广",
      "序号": 5
    },
    "校勘文": "翘翘错薪，言刈其楚。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "翘翘",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "翘翘，薪貌。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "错",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "错，杂也。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "楚",
        "粒度": "字",
        "注释类型": "笺注",
        "内容": "楚，杂薪之中尤翘翘者。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "翘翘错薪言刈其楚",
        "粒度": "句",
        "注释类型": "笺注",
        "内容": "我欲刈取之，以喻众女皆贞洁，我又欲取其尤高洁者。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "翘",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "翘，祁遥反，沈其尧反。",
        "文献id": "src001"
      }
    ]
  },
  {
