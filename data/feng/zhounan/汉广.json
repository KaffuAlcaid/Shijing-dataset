      "序号": 6
    },
    "校勘文": "之子于归，言秣其马。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "秣",
        "粒度": "字",
        "注释类型": "训诂",
