[
  {
    "id": "shijing_guofeng_zhounan_getan_s001",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "葛覃",
      "序号": 1
    },
    "校勘文": "葛之覃兮，施于中谷，维叶萋萋。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "葛之覃兮，施于中谷，维叶萋萋",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "兴也。"
      },
      {
        "id": "n002",
        "anchor": "覃",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "覃，延也。"
      },
      {
        "id": "n003",
        "anchor": "葛",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "葛所以为絺綌，女功之事烦辱者。"
      },
      {
        "id": "n004",
        "anchor": "施",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "施，移也。"
      },
      {
        "id": "n005",
        "anchor": "中谷",
        "粒度": "词",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "中谷，谷中也。"
      },
      {
        "id": "n006",
        "anchor": "萋萋",
        "粒度": "词",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "萋萋，茂盛貌。"
      },
      {
        "id": "n007",
        "anchor": "葛之覃兮，施于中谷，维叶萋萋",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "葛者，妇人之所有事也，此因葛之性以兴焉。兴者，葛延蔓于谷中，喻女在父母之家，形体浸浸日长大也。叶萋萋然，喻其容色美盛。"
      },
      {
        "id": "n008",
        "anchor": "施",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "施，毛以豉反，郑如字，下同。"
      },
      {
        "id": "n009",
        "anchor": "萋",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "萋切兮反。"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_getan_s002",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "葛覃",
      "序号": 2
    },
    "校勘文": "黄鸟于飞，集于灌木，其鸣喈喈。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "黄鸟",
        "粒度": "词",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "黄鸟，抟黍也。"
      },
      {
        "id": "n002",
        "anchor": "灌木",
        "粒度": "词",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "灌木，藂木也。"
      },
      {
        "id": "n003",
        "anchor": "喈喈",
        "粒度": "词",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "喈喈，和声之远闻也。"
      },
      {
        "id": "n004",
        "anchor": "黄鸟于飞，集于灌木，其鸣喈喈",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "葛延蔓之时，则抟黍飞鸣，亦因以兴焉。飞集藂木，兴女有嫁于君子之道。和声之远闻，兴女有才美之称达于远方。"
      },
      {
        "id": "n005",
        "anchor": "灌",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "灌，古乱反。"
      },
      {
        "id": "n006",
        "anchor": "喈",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "喈音皆。"
      },
      {
        "id": "n007",
        "anchor": "黄鸟",
        "粒度": "词",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "抟黍，徒端反，鸟名也。"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_getan_s003",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "葛覃",
      "序号": 3
    },
    "校勘文": "葛之覃兮，施于中谷，维叶莫莫。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "莫莫",
        "粒度": "词",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "莫莫，成就之貌。"
      },
      {
        "id": "n002",
        "anchor": "葛之覃兮，施于中谷，维叶莫莫",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "成就者，其可采用之时。"
      },
      {
        "id": "n003",
        "anchor": "莫",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "莫，美博反。"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_getan_s004",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "葛覃",
      "序号": 4
    },
    "校勘文": "是刈是濩，为絺为綌，服之无斁。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "濩",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "濩，煮之也。"
      },
      {
        "id": "n002",
        "anchor": "絺",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "精曰絺。"
      },
      {
        "id": "n003",
        "anchor": "綌",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "粗曰綌。"
      },
      {
        "id": "n004",
        "anchor": "斁",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "斁，厌也。"
      },
      {
        "id": "n005",
        "anchor": "是刈是濩，为絺为綌，服之无斁",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "句义",
        "内容": "古者王后织玄紞，公侯夫人紘綖，卿之内子大带，大夫命妇成祭服，士妻朝服，庶士以下各衣其夫。"
      },
      {
        "id": "n006",
        "anchor": "服",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "服，整也。"
      },
      {
        "id": "n007",
        "anchor": "是刈是濩，为絺为綌，服之无斁",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "女在父母之家，未知将所适，故习之以絺綌烦辱之事，乃能整治之无厌倦，是其性贞专。"
      },
      {
        "id": "n008",
        "anchor": "刈",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "校勘",
        "内容": "艾，本亦作「刈」，鱼废反。《韩诗》云：「刈，取也。」"
      },
      {
        "id": "n009",
        "anchor": "濩",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "濩，胡郭反，《韩诗》云：「濩，瀹也。音羊灼反」。"
      },
      {
        "id": "n010",
        "anchor": "絺",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "絺，耻知反。葛之精者曰絺。"
      },
      {
        "id": "n011",
        "anchor": "綌",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "綌，去逆反。"
      },
      {
        "id": "n012",
        "anchor": "斁",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "校勘",
        "内容": "斁，本亦作「𤢕」，音亦。"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_getan_s005",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "葛覃",
      "序号": 5
    },
    "校勘文": "言告师氏，言告言归。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "言",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "言，我也。"
      },
      {
        "id": "n002",
        "anchor": "师",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "师，女师也。"
      },
      {
        "id": "n003",
        "anchor": "言告师氏，言告言归",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "古者女师教以妇德、妇言、妇容、妇功。祖庙未毁，教于公宫三月。祖庙既毁，教于宗室。"
      },
      {
        "id": "n004",
        "anchor": "归",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "妇人谓嫁曰归。"
      },
      {
        "id": "n005",
        "anchor": "言告师氏，言告言归",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "我告师氏者，我见教告于女师也，教告我以适人之道。重言我者，尊重师教也。公宫、宗室，于族人皆为贵。"
      },
      {
        "id": "n006",
        "anchor": "归",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "校勘",
        "内容": "「谓嫁曰归」，本亦无「曰」字，此依《公羊传》文。"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_getan_s006",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "葛覃",
      "序号": 6
    },
    "校勘文": "薄污我私，薄浣我衣。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "污",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "污，烦也。"
      },
      {
        "id": "n002",
        "anchor": "私",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "私，燕服也。"
      },
      {
        "id": "n003",
        "anchor": "薄污我私，薄浣我衣",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "妇人有副褘盛饰，以朝事舅姑，接见于宗庙，进见于君子。其馀则私也。"
      },
      {
        "id": "n004",
        "anchor": "污",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "烦，烦撋之，用功深。"
      },
      {
        "id": "n005",
        "anchor": "浣",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "浣，谓濯之耳。"
      },
      {
        "id": "n006",
        "anchor": "衣",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "衣，谓褘衣以下至褖衣。"
      },
      {
        "id": "n007",
        "anchor": "污",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "污音乌。"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_getan_s007",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "葛覃",
      "序号": 7
    },
    "校勘文": "害浣害否？归宁父母。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "害",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "害，何也。"
      },
      {
        "id": "n002",
        "anchor": "害浣害否",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "句义",
        "内容": "私服宜浣，公服宜否。"
      },
      {
        "id": "n003",
        "anchor": "宁",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "宁，安也。父母在，则有时归宁耳。"
      },
      {
        "id": "n004",
        "anchor": "害浣害否，归宁父母",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "我之衣服，今者何所当见浣乎？何所当否乎？言常自洁清，以事君子。"
      },
      {
        "id": "n005",
        "anchor": "害",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "害，户葛反，下同。"
      },
      {
        "id": "n006",
        "anchor": "否",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "否，方九反。"
      }
    ]
  }
]