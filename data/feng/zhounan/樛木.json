  {"id":"n001","anchor":"南有樛木，葛藟累之","粒度":"句","文献id":"src001","注释类型":"训诂","内容":"兴也。"},
  {"id":"n002","anchor":"南","粒度":"字","文献id":"src001","注释类型":"训诂","内容":"南，南土也。"},
  {"id":"n003","anchor":"樛","粒度":"字","文献id":"src001","注释类型":"训诂","内容":"木下曲曰樛。"},
  {"id":"n004","anchor":"南有樛木，葛藟累之","粒度":"句","文献id":"src001","注释类型":"句义","内容":"南土之葛藟茂盛。"},
  {"id":"n005","anchor":"南有樛木，葛藟累之","粒度":"句","文献id":"src001","注释类型":"笺注","内容":"木枝以下垂之故，故葛也藟也得累而蔓之，而上下俱盛。"},
  {"id":"n006","anchor":"南有樛木，葛藟累之","粒度":"句","文献id":"src001","注释类型":"笺注","内容":"兴者，喻后妃能以意下逮众妾，使得其次序，则众妾上附事之，而礼义亦俱盛。"},
  {"id":"n007","anchor":"南土","粒度":"词","文献id":"src001","注释类型":"笺注","内容":"南土谓荆、杨之域。"},
  {"id":"n008","anchor":"藟","粒度":"字","文献id":"src001","注释类型":"校勘","内容":"本亦作「藟」。"},
  {"id":"n009","anchor":"藟","粒度":"字","文献id":"src001","注释类型":"音韵","内容":"力轨反。"},
  {"id":"n010","anchor":"藟","粒度":"字","文献id":"src001","注释类型":"考证","内容":"似葛之草。《草木疏》云：「一名巨荒，似燕薁，亦连蔓，叶似艾，白色，其子赤，可食。」"},
  {"id":"n011","anchor":"累","粒度":"字","文献id":"src001","注释类型":"音韵","内容":"力追反，缠绕也。"},
  {"id":"n012","anchor":"累","粒度":"字","文献id":"src001","注释类型":"校勘","内容":"木又作「累」。"},
  {"id":"n013","anchor":"上附","粒度":"词","文献id":"src001","注释类型":"音韵","内容":"上附，时掌反。"}
]
