[
  {
    "id": "shijing_guofeng_zhounan_zhongsi_s001",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "螽斯",
      "序号": 1
    },
    "校勘文": "螽斯羽，诜诜兮。",
    "今译": "",
    "注音": "",
    "注释": [
  {
    "id": "n001",
    "anchor": "螽斯",
    "粒度": "词",
    "文献id": "src001",
    "注释类型": "训诂",
    "内容": "螽斯，蚣蝑也。"
  },
  {
    "id": "n002",
    "anchor": "诜诜",
    "粒度": "词",
    "文献id": "src001",
    "注释类型": "训诂",
    "内容": "诜诜，众多也。"
  },
  {
    "id": "n003",
    "anchor": "螽斯羽，诜诜兮",
    "粒度": "句",
    "文献id": "src001",
    "注释类型": "笺注",
    "内容": "凡物有阴阳情欲者无不妒忌，维蚣蝑不耳，各得受气而生子，故能诜诜然众多。后妃之德能如是，则宜然。"
  },
  {
    "id": "n004",
    "anchor": "诜",
    "粒度": "字",
    "文献id": "src001",
    "注释类型": "音韵",
    "内容": "诜，所巾反，《说文》作「𨐔」，音同。"
  },
  {
    "id": "n005",
    "anchor": "诜",
    "粒度": "字",
    "文献id": "src001",
    "注释类型": "校勘",
    "内容": "《说文》作「𨐔」。"
  },
  {
    "id": "n006",
    "anchor": "蚣",
    "粒度": "字",
    "文献id": "src001",
    "注释类型": "音韵",
    "内容": "蚣，粟容反，《字林》作「蜙」，先凶反。郭璞先工反，许慎思弓反。"
  },
  {
    "id": "n007",
    "anchor": "蚣",
    "粒度": "字",
    "文献id": "src001",
    "注释类型": "校勘",
    "内容": "《字林》作「蜙」。"
  },
  {
    "id": "n008",
    "anchor": "蝑",
    "粒度": "字",
    "文献id": "src001",
    "注释类型": "音韵",
    "内容": "蝑，粟居反，许慎、吕沈并先吕反，郭璞才与反。"
  },
  {
    "id": "n009",
    "anchor": "螽斯",
    "粒度": "词",
    "文献id": "src001",
    "注释类型": "考证",
    "内容": "案一名斯螽，《七月》诗云「斯螽动股」是也。扬雄、许慎皆云「舂黍」。《草木疏》云：「幽州谓之舂箕，蝗类也，长而青，长股，股鸣者也。」郭璞注《方言》云：「江东呼为虴蜢，音竹帛反。」蜢音猛。"
  },
  {
    "id": "n010",
    "anchor": "螽斯羽，诜诜兮",
    "粒度": "句",
    "文献id": "src001",
    "注释类型": "音韵",
    "内容": "欲音欲，诸诠之音谕。"
  },
  {
    "id": "n011",
    "anchor": "螽斯羽，诜诜兮",
    "粒度": "句",
    "文献id": "src001",
    "注释类型": "校勘",
    "内容": "「不耳」，本或作「不然」。"
  }
]
  },
  {
    "id": "shijing_guofeng_zhounan_zhongsi_s002",
