    "anchor": "振振",
    "粒度": "词",
    "文献id": "src001",
    "注释类型": "训诂",
    "内容": "振振，仁厚也。"
  },
  {
    "id": "n002",
    "anchor": "宜尔子孙，振振兮",
    "粒度": "句",
    "文献id": "src001",
    "注释类型": "句义",
    "内容": "后妃之德宽容不嫉妒，则宜女之子孙，使其无不仁厚。"
  },
  {
    "id": "n003",
    "anchor": "振",
    "粒度": "字",
    "文献id": "src001",
    "注释类型": "音韵",
    "内容": "振音真。"
  }
]
  },
  {
