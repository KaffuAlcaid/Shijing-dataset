      "序号": 1
    },
    "校勘文": "采采芣苡，薄言采之。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "采采",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "采采，非一辞也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "芣苡",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "芣苡，马舄。马舄，车前也，宜怀任焉。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "薄",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "薄，辞也。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "采",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "采，取也。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "薄言",
        "粒度": "词",
        "注释类型": "笺注",
        "内容": "薄言，我薄也。",
        "文献id": "src001"
      }
    ]
  },
