[
  {
    "id": "shijing_guofeng_zhounan_tuju_s001",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "兔罝",
      "序号": 1
    },
    "校勘文": "肃肃兔罝，椓之丁丁。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "肃肃",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "肃肃，敬也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "兔罝",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "兔罝，兔罟也。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "丁丁",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "丁丁，椓杙声也。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "肃肃兔罝椓之丁丁",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "罝兔之人，鄙贱之事，犹能恭敬，则是贤者众多也。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "椓",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "椓，陟角反。",
        "文献id": "src001"
      },
      {
        "id": "n006",
        "anchor": "丁",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "丁，陟耕反。",
        "文献id": "src001"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_tuju_s002",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "兔罝",
      "序号": 2
    },
    "校勘文": "赳赳武夫，公侯干城。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n007",
        "anchor": "赳赳",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "赳赳，武貌。",
        "文献id": "src001"
      },
      {
        "id": "n008",
        "anchor": "干",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "乾，捍也。",
        "文献id": "src001"
      },
      {
        "id": "n009",
        "anchor": "干",
        "粒度": "字",
        "注释类型": "笺注",
        "内容": "乾也，皆以御难也。",
        "文献id": "src001"
      },
      {
        "id": "n010",
        "anchor": "城",
        "粒度": "字",
        "注释类型": "笺注",
        "内容": "城也，皆以御难也。",
        "文献id": "src001"
      },
      {
        "id": "n011",
        "anchor": "赳赳武夫公侯干城",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "此罝兔之人，贤者也，有武力，可任为将帅之德，诸侯可任以国守，捍城其民，折冲御难于未然。",
        "文献id": "src001"
      },
      {
        "id": "n012",
        "anchor": "赳",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "赳，居黝反。",
        "文献id": "src001"
      },
      {
        "id": "n013",
        "anchor": "赳",
        "粒度": "字",
        "注释类型": "考证",
        "内容": "《尔雅》云：「勇也。」",
        "文献id": "src001"
      },
      {
        "id": "n014",
        "anchor": "干",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "干如字，旧户旦反，沈音干。",
        "文献id": "src001"
      },
      {
        "id": "n015",
        "anchor": "干",
        "粒度": "字",
        "注释类型": "考证",
        "内容": "孙炎注云：「乾，楯，所以自蔽捍也。」",
        "文献id": "src001"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_tuju_s003",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "兔罝",
      "序号": 3
    },
    "校勘文": "肃肃兔罝，施于中逵。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n016",
        "anchor": "逵",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "逵，九达之道。",
        "文献id": "src001"
      },
      {
        "id": "n017",
        "anchor": "施",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "施，如字。",
        "文献id": "src001"
      },
      {
        "id": "n018",
        "anchor": "逵",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "逵，求龟反。",
        "文献id": "src001"
      },
      {
        "id": "n019",
        "anchor": "逵",
        "粒度": "字",
        "注释类型": "考证",
        "内容": "杜预注《春秋》云：「涂方九轨。」",
        "文献id": "src001"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_tuju_s004",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "兔罝",
      "序号": 4
    },
    "校勘文": "赳赳武夫，公侯好仇。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n020",
        "anchor": "仇",
        "粒度": "字",
        "注释类型": "笺注",
        "内容": "怨耦曰仇。",
        "文献id": "src001"
      },
      {
        "id": "n021",
        "anchor": "赳赳武夫公侯好仇",
        "粒度": "句",
        "注释类型": "笺注",
        "内容": "此罝兔之人，敌国有来侵伐者，可使和好之，亦言贤也。",
        "文献id": "src001"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_tuju_s005",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "兔罝",
      "序号": 5
    },
    "校勘文": "肃肃兔罝，施于中林。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n022",
        "anchor": "中林",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "中林，林中。",
        "文献id": "src001"
      },
      {
        "id": "n023",
        "anchor": "施",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "施如字，沈以豉反。",
        "文献id": "src001"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_tuju_s006",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "兔罝",
      "序号": 6
    },
    "校勘文": "赳赳武夫，公侯腹心。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n024",
        "anchor": "腹心",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "可以制断，公侯之腹心。",
        "文献id": "src001"
      },
      {
        "id": "n025",
        "anchor": "赳赳武夫公侯腹心",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "此罝兔之人，于行攻伐，可用为策谋之臣，使之虑无，亦言贤也。",
        "文献id": "src001"
      }
    ]
  }
]