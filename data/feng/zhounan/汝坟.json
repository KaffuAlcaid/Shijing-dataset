[
  {
    "id": "shijing_guofeng_zhounan_rufen_s001",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "汝坟",
      "序号": 1
    },
    "校勘文": "遵彼汝坟，伐其条枚。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "遵",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "遵，循也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "汝",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "汝，水名也。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "坟",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "坟，大防也。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "条",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "枝曰条",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "枚",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "乾曰枚",
        "文献id": "src001"
      },
      {
        "id": "n006",
        "anchor": "遵彼汝坟伐其条枚",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "伐薪于汝水之侧，非妇人之事，以言己之君子贤者，而处勤劳之职，亦非其事。",
        "文献id": "src001"
      },
      {
        "id": "n007",
        "anchor": "枚",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "枚，妹回反",
        "文献id": "src001"
      },
      {
        "id": "n008",
        "anchor": "枚",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "乾也",
        "文献id": "src001"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_rufen_s002",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "汝坟",
      "序号": 2
    },
    "校勘文": "未见君子，惄如调饥。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "惄",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "惄，饥意也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "调",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "调，朝也。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "惄",
        "粒度": "字",
        "注释类型": "笺注",
        "内容": "惄，思也。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "未见君子惄如调饥",
        "粒度": "句",
        "注释类型": "笺注",
        "内容": "未见君子之时，如朝饥之思食。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "惄",
        "粒度": "字",
        "注释类型": "校勘",
        "内容": "纣心本又作「惄」",
        "文献id": "src001"
      },
      {
        "id": "n006",
        "anchor": "惄",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "乃历反",
        "文献id": "src001"
      },
      {
        "id": "n007",
        "anchor": "惄",
        "粒度": "字",
        "注释类型": "校勘",
        "内容": "《韩诗》作「溺」，音同",
        "文献id": "src001"
      },
      {
        "id": "n008",
        "anchor": "调",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "张留反",
        "文献id": "src001"
      },
      {
        "id": "n009",
        "anchor": "调",
        "粒度": "字",
        "注释类型": "校勘",
        "内容": "又作「輖」，音同",
        "文献id": "src001"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_rufen_s003",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "汝坟",
      "序号": 3
    },
    "校勘文": "遵彼汝坟，伐其条肄。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "肄",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "肄，馀也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "肄",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "斩而复生曰肄。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "肄",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "肄，以自反。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "肄",
        "粒度": "字",
        "注释类型": "考证",
        "内容": "沈云：「徐音以世反，非。」",
        "文献id": "src001"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_rufen_s004",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "汝坟",
      "序号": 4
    },
    "校勘文": "既见君子，不我遐弃。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "既",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "既，已。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "遐",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "遐，远也。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "既见君子不我遐弃",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "己见君子，君子反也，于已反得见之，知其不远弃我而死亡，于思则愈，故下章而勉之。",
        "文献id": "src001"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_rufen_s005",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "汝坟",
      "序号": 5
    },
    "校勘文": "鲂鱼赬尾，王室如毁。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "赬",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "赬，赤也，鱼劳则尾赤。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "毁",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "毁，火也。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "鲂鱼赬尾王室如毁",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "君子仕于乱世，其颜色瘦病，如鱼劳则尾赤。所以然者，畏王室之酷烈。是时纣存。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "鲂",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "符方反",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "鲂",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "鱼名",
        "文献id": "src001"
      },
      {
        "id": "n006",
        "anchor": "赬",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "敕贞反",
        "文献id": "src001"
      },
      {
        "id": "n007",
        "anchor": "赬",
        "粒度": "字",
        "注释类型": "校勘",
        "内容": "《说文》作「䞓」，又作「赬」，并同。",
        "文献id": "src001"
      },
      {
        "id": "n008",
        "anchor": "毁",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "毁音毁",
        "文献id": "src001"
      },
      {
        "id": "n009",
        "anchor": "毁",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "郭璞又音货",
        "文献id": "src001"
      },
      {
        "id": "n010",
        "anchor": "毁",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "一音火尾反",
        "文献id": "src001"
      },
      {
        "id": "n011",
        "anchor": "毁",
        "粒度": "字",
        "注释类型": "校勘",
        "内容": "字书作「尾」，音毁，《说文》同。",
        "文献id": "src001"
      },
      {
        "id": "n012",
        "anchor": "毁",
        "粒度": "字",
        "注释类型": "考证",
        "内容": "或云：楚人名曰燥，齐人曰毁，吴人曰尾，此方俗讹语也。",
        "文献id": "src001"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_rufen_s006",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "汝坟",
      "序号": 6
    },
    "校勘文": "虽则如毁，父母孔迩。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "孔",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "孔，甚。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "迩",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "迩，近也。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "虽则如毁父母孔迩",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "辟此勤劳之处，或时得罪，父母甚近，当念之，以免于害，不能为疏远者计也。",
        "文献id": "src001"
      }
    ]
  }
]