[
  {
    "id": "shijing_guofeng_zhounan_juaner_s001",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "卷耳",
      "序号": 1
    },
    "校勘文": "采采卷耳，不盈顷筐。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "采采卷耳，不盈顷筐",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "忧者，之兴也。"
      },
      {
        "id": "n002",
        "anchor": "采采",
        "粒度": "词",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "事采之也。"
      },
      {
        "id": "n003",
        "anchor": "卷耳",
        "粒度": "词",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "苓耳也。"
      },
      {
        "id": "n004",
        "anchor": "顷筐",
        "粒度": "词",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "畚属，易盈之器也。"
      },
      {
        "id": "n005",
        "anchor": "采采卷耳，不盈顷筐",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "器之易盈而不盈者，志在辅佐君子，忧思深也。"
      },
      {
        "id": "n006",
        "anchor": "顷",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "顷音倾。"
      },
      {
        "id": "n007",
        "anchor": "筐",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "筐，起狂反。"
      },
      {
        "id": "n008",
        "anchor": "顷筐",
        "粒度": "词",
        "文献id": "src001",
        "注释类型": "校勘",
        "内容": "《韩诗》云：「顷筐，欹筐也。」"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_juaner_s002",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "卷耳",
      "序号": 2
    },
    "校勘文": "嗟我怀人，寘彼周行。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "嗟我怀人，置彼周行",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "思君子官贤人，置周之列位。"
      },
      {
        "id": "n002",
        "anchor": "怀",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "怀，思。"
      },
      {
        "id": "n003",
        "anchor": "置",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "置，置。"
      },
      {
        "id": "n004",
        "anchor": "行",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "行，列也。"
      },
      {
        "id": "n005",
        "anchor": "周行",
        "粒度": "词",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "周之列位，谓朝廷臣也。"
      },
      {
        "id": "n006",
        "anchor": "置",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "置，之豉反。"
      },
      {
        "id": "n007",
        "anchor": "行",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "行，户康反。注下同。"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_juaner_s003",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "卷耳",
      "序号": 3
    },
    "校勘文": "陟彼崔嵬，我马虺隤。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "陟",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "陟，升也。"
      },
      {
        "id": "n002",
        "anchor": "崔嵬",
        "粒度": "词",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "崔嵬，土山之戴石者。"
      },
      {
        "id": "n003",
        "anchor": "虺隤",
        "粒度": "词",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "虺隤，病也。"
      },
      {
        "id": "n004",
        "anchor": "我",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "我，我使臣也。"
      },
      {
        "id": "n005",
        "anchor": "陟彼崔嵬，我马虺隤",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "臣以兵役之事行出，离其列位，身勤劳于山险，而马又病，君子宜知其然。"
      },
      {
        "id": "n006",
        "anchor": "崔",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "崔，徂回反。"
      },
      {
        "id": "n007",
        "anchor": "嵬",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "嵬，五回反。"
      },
      {
        "id": "n008",
        "anchor": "虺",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "虺，呼回反，徐呼怀反。"
      },
      {
        "id": "n009",
        "anchor": "虺",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "校勘",
        "内容": "《说文》作「㾯」。"
      },
      {
        "id": "n010",
        "anchor": "隤",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "隤，徒回反，徐徒坏反，《尔雅》同。"
      },
      {
        "id": "n011",
        "anchor": "隤",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "校勘",
        "内容": "《说文》作「颓」。"
      },
      {
        "id": "n012",
        "anchor": "隤",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "考证",
        "内容": "孙炎云：「马退不能升之病也。」"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_juaner_s004",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "卷耳",
      "序号": 4
    },
    "校勘文": "我姑酌彼金罍，维以不永怀。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "姑",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "姑，且也。"
      },
      {
        "id": "n002",
        "anchor": "永",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "永，长也。"
      },
      {
        "id": "n003",
        "anchor": "金罍",
        "粒度": "词",
        "文献id": "src001",
        "注释类型": "句义",
        "内容": "人君黄金罍。"
      },
      {
        "id": "n004",
        "anchor": "我",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "我，我君也。"
      },
      {
        "id": "n005",
        "anchor": "我姑酌彼金罍，维以不永怀",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "臣出使，功成而反，君且当设飨燕之礼，与之饮酒以劳之，我则以是不复长忧思也。"
      },
      {
        "id": "n006",
        "anchor": "姑",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "言且者，君赏功臣，或多于此。"
      },
      {
        "id": "n007",
        "anchor": "姑",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "姑如字。"
      },
      {
        "id": "n008",
        "anchor": "姑",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "校勘",
        "内容": "《说文》作「夃」，音同，云「秦以市买多得为夃」。"
      },
      {
        "id": "n009",
        "anchor": "罍",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "罍，卢回反，酒樽也。"
      },
      {
        "id": "n010",
        "anchor": "罍",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "校勘",
        "内容": "《韩诗》云：「天子以玉饰，诸侯、大夫皆以黄金饰，士以梓。」"
      },
      {
        "id": "n011",
        "anchor": "罍",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "句义",
        "内容": "《礼记》云：「夏曰山罍，其形似壶，容一斛，刻而画之，为云雷之形。」"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_juaner_s005",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "卷耳",
      "序号": 5
    },
    "校勘文": "陟彼高冈，我马玄黄。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "冈",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "山脊曰冈。"
      },
      {
        "id": "n002",
        "anchor": "玄",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "玄，马病则黄。"
      },
      {
        "id": "n003",
        "anchor": "冈",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "冈，古康反。"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_juaner_s006",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "卷耳",
      "序号": 6
    },
    "校勘文": "我姑酌彼兕觥，维以不永伤。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "我姑酌彼兕觥，维以不永伤",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "此章为意不尽，申殷勤也。"
      },
      {
        "id": "n002",
        "anchor": "兕觥",
        "粒度": "词",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "兕觥，角爵也。"
      },
      {
        "id": "n003",
        "anchor": "伤",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "伤，思也。"
      },
      {
        "id": "n004",
        "anchor": "觥",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "觥，罚爵也。飨燕所以有之者，礼自立司正之后，旅酬必有醉而失礼者，罚之亦所以为乐。"
      },
      {
        "id": "n005",
        "anchor": "兕",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "校勘",
        "内容": "字又作兕。"
      },
      {
        "id": "n006",
        "anchor": "兕",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "徐履反。"
      },
      {
        "id": "n007",
        "anchor": "觥",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "觥，古横反。"
      },
      {
        "id": "n008",
        "anchor": "觥",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "考证",
        "内容": "以兕角为之。"
      },
      {
        "id": "n009",
        "anchor": "觥",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "校勘",
        "内容": "字又作「觥」。"
      },
      {
        "id": "n010",
        "anchor": "觥",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "考证",
        "内容": "《韩诗》云容五升，《礼图》云容七升。"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_juaner_s007",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "卷耳",
      "序号": 7
    },
    "校勘文": "陟彼砠矣，我马瘏矣。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "砠",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "石山戴土曰砠。"
      },
      {
        "id": "n002",
        "anchor": "砠",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "校勘",
        "内容": "本亦作「砠」。"
      },
      {
        "id": "n003",
        "anchor": "砠",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "同七馀反。"
      },
      {
        "id": "n004",
        "anchor": "瘏",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "瘏，病也。"
      },
      {
        "id": "n005",
        "anchor": "瘏",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "音涂。"
      },
      {
        "id": "n006",
        "anchor": "瘏",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "校勘",
        "内容": "本又作「屠」，非。"
      }
    ]
  },
  {
    "id": "shijing_guofeng_zhounan_juaner_s008",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "卷耳",
      "序号": 8
    },
    "校勘文": "我仆痡矣，云何吁矣！",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "痡",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "痡，病也。"
      },
      {
        "id": "n002",
        "anchor": "吁",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "训诂",
        "内容": "吁，忧也。"
      },
      {
        "id": "n003",
        "anchor": "我仆痡矣，云何吁矣",
        "粒度": "句",
        "文献id": "src001",
        "注释类型": "笺注",
        "内容": "此章言臣既勤劳于外，仆马皆病，而今云何乎其亦忧矣，深闵之辞。"
      },
      {
        "id": "n004",
        "anchor": "痡",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "音敷，又普乌反。"
      },
      {
        "id": "n005",
        "anchor": "痡",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "校勘",
        "内容": "本又作「铺」，同。"
      },
      {
        "id": "n006",
        "anchor": "痡",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "校勘",
        "内容": "「痡，病也」，一本作「痡，亦病也」者，非。"
      },
      {
        "id": "n007",
        "anchor": "吁",
        "粒度": "字",
        "文献id": "src001",
        "注释类型": "音韵",
        "内容": "香于反。"
      }
    ]
  }
]