[
  {
    "id": "shi_feng_zhounan_guanju-s001",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "关雎",
      "序号": 1
    },
    "校勘文": "关关雎鸠，在河之洲。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "关关雎鸠，在河之洲",
        "粒度": "句",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "兴也。"
      },
      {
        "id": "n002",
        "anchor": "关关",
        "粒度": "词",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "关关，和声也。"
      },
      {
        "id": "n003",
        "anchor": "雎鸠",
        "粒度": "词",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "雎鸠，王雎也，鸟挚而有别。"
      },
      {
        "id": "n004",
        "anchor": "洲",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "水中可居者曰洲。"
      },
      {
        "id": "n005",
        "anchor": "关关雎鸠，在河之洲",
        "粒度": "句",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "后妃说乐君子之德，无不和谐，又不淫其色，慎固幽深，若关雎之有别焉，然后可以风化天下。夫妇有别则父子亲，父子亲则君臣敬，君臣敬则朝廷正，朝廷正则王化成。"
      },
      {
        "id": "n006",
        "anchor": "雎鸠",
        "粒度": "词",
        "文献id": "scr001",
        "注释类型": "笺注",
        "内容": "挚之言至也，谓王雎之鸟，雌雄情意至然而有别。"
      },
      {
        "id": "n007",
        "anchor": "雎",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "音韵",
        "内容": "雎，七胥反。"
      },
      {
        "id": "n008",
        "anchor": "鸠",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "音韵",
        "内容": "鸠，九尢反，鸟之有至别者。"
      },
      {
        "id": "n009",
        "anchor": "洲",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "音韵",
        "内容": "洲音州。"
      }
    ]
  },
  {
    "id": "shi_feng_zhounan_guanju-s002",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "关雎",
      "序号": 2
    },
    "校勘文": "窈窕淑女，君子好逑。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "窈窕",
        "粒度": "词",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "窈窕，幽闲也。"
      },
      {
        "id": "n002",
        "anchor": "淑",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "淑，善。"
      },
      {
        "id": "n003",
        "anchor": "逑",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "逑，匹也。"
      },
      {
        "id": "n004",
        "anchor": "窈窕淑女，君子好逑",
        "粒度": "句",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "言后妃有关雎之德，是幽闲贞专之善女，宜为君子之好匹。"
      },
      {
        "id": "n005",
        "anchor": "逑",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "笺注",
        "内容": "怨耦曰仇。"
      },
      {
        "id": "n006",
        "anchor": "窈窕淑女，君子好逑",
        "粒度": "句",
        "文献id": "scr001",
        "注释类型": "笺注",
        "内容": "言后妃之德和谐，则幽闲处深宫贞专之善女，能为君子和好众妾之怨者。言皆化后妃之德，不嫉妒，谓三夫人以下。"
      },
      {
        "id": "n007",
        "anchor": "好",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "音韵",
        "内容": "好，毛如字，郑呼报反。《兔罝》诗放此。"
      },
      {
        "id": "n008",
        "anchor": "逑",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "音韵",
        "内容": "逑音求，毛云「匹也」，本亦作仇，音同。郑云「怨耦曰仇」。"
      }
    ]
  },
  {
    "id": "shi_feng_zhounan_guanju-s003",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "关雎",
      "序号": 3
    },
    "校勘文": "参差荇菜，左右流之。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "荇",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "荇，接馀也。"
      },
      {
        "id": "n002",
        "anchor": "流",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "流，求也。"
      },
      {
        "id": "n003",
        "anchor": "参差荇菜，左右流之",
        "粒度": "句",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "后妃有关雎之德，乃能共荇菜，备庶物，以事宗庙也。"
      },
      {
        "id": "n004",
        "anchor": "左右",
        "粒度": "词",
        "文献id": "scr001",
        "注释类型": "笺注",
        "内容": "左右，助也。"
      },
      {
        "id": "n005",
        "anchor": "参差荇菜，左右流之",
        "粒度": "句",
        "文献id": "scr001",
        "注释类型": "笺注",
        "内容": "言后妃将共荇菜之菹，必有助而求之者。言三夫人、九嫔以下，皆乐后妃之乐。"
      },
      {
        "id": "n006",
        "anchor": "参",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "音韵",
        "内容": "参，初金反。"
      },
      {
        "id": "n007",
        "anchor": "差",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "音韵",
        "内容": "差，初宜反，又初佳反。"
      },
      {
        "id": "n008",
        "anchor": "荇",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "音韵",
        "内容": "荇，衡猛反，沈有并反。"
      },
      {
        "id": "n009",
        "anchor": "荇",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "校勘",
        "内容": "本亦作荇。"
      },
      {
        "id": "n010",
        "anchor": "左右",
        "粒度": "词",
        "文献id": "scr001",
        "注释类型": "音韵",
        "内容": "左右，王申毛如字；郑上音佐，下音佑。"
      }
    ]
  },
  {
    "id": "shi_feng_zhounan_guanju-s004",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "关雎",
      "序号": 4
    },
    "校勘文": "窈窕淑女，寤寐求之。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "寤",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "寤，觉。"
      },
      {
        "id": "n002",
        "anchor": "寐",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "寐，寝也。"
      },
      {
        "id": "n003",
        "anchor": "窈窕淑女，寤寐求之",
        "粒度": "句",
        "文献id": "scr001",
        "注释类型": "笺注",
        "内容": "言后妃觉寐则常求此贤女，欲与之共已职也。"
      },
      {
        "id": "n004",
        "anchor": "寤",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "音韵",
        "内容": "寤，五路反。"
      },
      {
        "id": "n005",
        "anchor": "寐",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "音韵",
        "内容": "寐，莫利反。"
      }
    ]
  },
  {
    "id": "shi_feng_zhounan_guanju-s005",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "关雎",
      "序号": 5
    },
    "校勘文": "求之不得，寤寐思服。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "服",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "服，思之也。"
      },
      {
        "id": "n002",
        "anchor": "服",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "笺注",
        "内容": "服，事也。"
      },
      {
        "id": "n003",
        "anchor": "求之不得，寤寐思服",
        "粒度": "句",
        "文献id": "scr001",
        "注释类型": "笺注",
        "内容": "求贤女而不得，觉寐则思己职事当谁与共之乎！"
      }
    ]
  },
  {
    "id": "shi_feng_zhounan_guanju-s006",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "关雎",
      "序号": 6
    },
    "校勘文": "悠哉悠哉，辗转反侧。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "悠",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "悠，思也。"
      },
      {
        "id": "n002",
        "anchor": "悠哉悠哉",
        "粒度": "句",
        "文献id": "scr001",
        "注释类型": "笺注",
        "内容": "思之哉！思之哉！言已诚思之。"
      },
      {
        "id": "n003",
        "anchor": "辗",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "笺注",
        "内容": "卧而不周曰辗。"
      },
      {
        "id": "n004",
        "anchor": "悠",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "音韵",
        "内容": "悠音由。"
      },
      {
        "id": "n005",
        "anchor": "辗",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "音韵",
        "内容": "辗，哲善反。"
      },
      {
        "id": "n006",
        "anchor": "辗",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "校勘",
        "内容": "辗，本亦作展，吕忱从车、展。"
      },
      {
        "id": "n007",
        "anchor": "辗",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "校勘",
        "内容": "郑云「不周曰辗」，注本或作「卧而不周」者，剩二字也。"
      }
    ]
  },
  {
    "id": "shi_feng_zhounan_guanju-s007",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "关雎",
      "序号": 7
    },
    "校勘文": "参差荇菜，左右采之。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "参差荇菜，左右采之",
        "粒度": "句",
        "文献id": "scr001",
        "注释类型": "笺注",
        "内容": "言后妃既得荇菜，必有助而采之者。"
      }
    ]
  },
  {
    "id": "shi_feng_zhounan_guanju-s008",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "关雎",
      "序号": 8
    },
    "校勘文": "窈窕淑女，琴瑟友之。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "窈窕淑女，琴瑟友之",
        "粒度": "句",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "宜以琴瑟友乐之。"
      },
      {
        "id": "n002",
        "anchor": "友",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "笺注",
        "内容": "同志为友。"
      },
      {
        "id": "n003",
        "anchor": "窈窕淑女，琴瑟友之",
        "粒度": "句",
        "文献id": "scr001",
        "注释类型": "笺注",
        "内容": "言贤女之助后妃共荇菜，其情意乃与琴瑟之志同，共荇菜之时，乐必作。"
      }
    ]
  },
  {
    "id": "shi_feng_zhounan_guanju-s009",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "关雎",
      "序号": 9
    },
    "校勘文": "参差荇菜，左右芼之。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "芼",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "芼，择也。"
      },
      {
        "id": "n002",
        "anchor": "参差荇菜，左右芼之",
        "粒度": "句",
        "文献id": "scr001",
        "注释类型": "笺注",
        "内容": "后妃既得荇菜，必有助而择之者。"
      },
      {
        "id": "n003",
        "anchor": "芼",
        "粒度": "字",
        "文献id": "scr001",
        "注释类型": "音韵",
        "内容": "芼，毛报反。"
      }
    ]
  },
  {
    "id": "shi_feng_zhounan_guanju-s010",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "关雎",
      "序号": 10
    },
    "校勘文": "窈窕淑女，钟鼓乐之。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "窈窕淑女，钟鼓乐之",
        "粒度": "句",
        "文献id": "scr001",
        "注释类型": "训诂",
        "内容": "德盛者宜有钟鼓之乐。"
      },
      {
        "id": "n002",
        "anchor": "窈窕淑女，钟鼓乐之",
        "粒度": "句",
        "文献id": "scr001",
        "注释类型": "笺注",
        "内容": "琴瑟在堂，钟鼓在庭，言共荇菜之时！上下之乐皆作，盛其礼也。"
      },
      {
        "id": "n003",
        "anchor": "乐之",
        "粒度": "词",
        "文献id": "scr001",
        "注释类型": "音韵",
        "内容": "「乐之」音洛，又音岳。或云协韵，宜五教反。"
      }
    ]
  }
]