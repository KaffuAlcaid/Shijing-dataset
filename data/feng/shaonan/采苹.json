[
  {
    "id": "shijing_guofeng_shaonan_caiping_s001",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "采苹",
      "序号": 1
    },
    "校勘文": "于以采苹？南涧之滨。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "苹",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "苹，大蓱也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "滨",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "滨，涯也。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "于以采苹南涧之滨",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "古者妇人先嫁三月，祖庙未毁，教于公宫；祖庙既毁，教于宗室。教以妇德、妇言、妇容、妇功。教成之祭，牲用鱼，芼用苹藻，所以成妇顺也。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "于以采苹南涧之滨",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "此祭，祭女所出祖也。法度莫大于四教，是又祭以成之，故举以言焉。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "苹",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "苹之言宾也。",
        "文献id": "src001"
      },
      {
        "id": "n006",
        "anchor": "于以采苹南涧之滨",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "妇人之行，尚柔顺，自洁清，故取名以为戒。",
        "文献id": "src001"
      },
      {
        "id": "n007",
        "anchor": "滨",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "滨音宾，涯也。",
        "文献id": "src001"
      },
      {
        "id": "n008",
        "anchor": "苹",
        "粒度": "字",
        "注释类型": "校勘",
        "内容": "蓱本又作「萍」，薄经反，一本作「苹」，音平。",
        "文献id": "src001"
      }
    ]
  },
  {
    "id": "shijing_guofeng_shaonan_caiping_s002",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "采苹",
      "序号": 2
    },
    "校勘文": "于以采藻？于彼行潦。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "藻",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "藻，聚藻也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "行潦",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "行潦，流潦也。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "于以采藻于彼行潦",
        "粒度": "句",
        "注释类型": "笺注",
        "内容": "古者妇人先嫁三月，祖庙未毁，教于公宫；祖庙既毁，教于宗室。教以妇德、妇言、妇容、妇功。教成之祭，牲用鱼，芼用苹藻，所以成妇顺也。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "于以采藻于彼行潦",
        "粒度": "句",
        "注释类型": "笺注",
        "内容": "此祭，祭女所出祖也。法度莫大于四教，是又祭以成之，故举以言焉。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "藻",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "藻之言澡也。",
        "文献id": "src001"
      },
      {
        "id": "n006",
        "anchor": "于以采藻于彼行潦",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "妇人之行，尚柔顺，自洁清，故取名以为戒。",
        "文献id": "src001"
      },
      {
        "id": "n007",
        "anchor": "藻",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "藻音早，水菜也。",
        "文献id": "src001"
      },
      {
        "id": "n008",
        "anchor": "潦",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "潦音老。",
        "文献id": "src001"
      },
      {
        "id": "n009",
        "anchor": "行",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "行，下孟反。",
        "文献id": "src001"
      }
    ]
  },
  {
    "id": "shijing_guofeng_shaonan_caiping_s003",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "采苹",
      "序号": 3
    },
    "校勘文": "于以盛之？维筐及筥。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "筐",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "方曰筐。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "筥",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "圆曰筥。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "盛",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "盛音成。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "筐",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "筐音匡。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "筥",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "筥，居吕反。",
        "文献id": "src001"
      }
    ]
  },
  {
    "id": "shijing_guofeng_shaonan_caiping_s004",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "采苹",
      "序号": 4
    },
    "校勘文": "于以湘之？维锜及釜。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "湘",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "湘，亨也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "锜",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "锜，釜属，有足曰锜",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "釜",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "无足曰釜",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "湘",
        "粒度": "字",
        "注释类型": "笺注",
        "内容": "亨苹藻者于鱼湆之中，是鉶之芼。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "湘",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "湘，息良反。",
        "文献id": "src001"
      },
      {
        "id": "n006",
        "anchor": "锜",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "锜，其绮反，三足釜也，《玉篇》宜绮反。",
        "文献id": "src001"
      },
      {
        "id": "n007",
        "anchor": "釜",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "釜，符甫反。",
        "文献id": "src001"
      }
    ]
  },
  {
    "id": "shijing_guofeng_shaonan_caiping_s005",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "采苹",
      "序号": 5
    },
    "校勘文": "于以奠之？宗室牖下。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "奠",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "奠，置也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "宗室",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "宗室，大宗之庙也。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "于以奠之宗室牖下",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "大夫士祭于宗庙，奠于牖下。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "牖下",
        "粒度": "词",
        "注释类型": "笺注",
        "内容": "牖下，户牖闲之前。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "于以奠之宗室牖下",
        "粒度": "句",
        "注释类型": "笺注",
        "内容": "祭不于室中者，凡昏事，于女礼设几筵于户外，此其义也与？",
        "文献id": "src001"
      },
      {
        "id": "n006",
        "anchor": "于以奠之宗室牖下",
        "粒度": "句",
        "注释类型": "笺注",
        "内容": "宗子主此祭，维君使有司为之。",
        "文献id": "src001"
      },
      {
        "id": "n007",
        "anchor": "牖",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "牖音酉。",
        "文献id": "src001"
      },
      {
        "id": "n008",
        "anchor": "下",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "下如字，协韵则音户，后皆放此。",
        "文献id": "src001"
      }
    ]
  },
  {
    "id": "shijing_guofeng_shaonan_caiping_s006",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "采苹",
      "序号": 6
    },
    "校勘文": "谁其尸之？有齐季女。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "尸",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "尸，主。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "齐",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "齐，敬。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "季",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "季，少也。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "谁其尸之有齐季女",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "苹藻，薄物也。涧潦，至质也。筐筥锜釜，陋器也。少女，微主也。古之将嫁女者，必先礼之于宗室，牲用鱼，芼之以苹藻。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "谁其尸之有齐季女",
        "粒度": "句",
        "注释类型": "笺注",
        "内容": "主设羹者季女，则非礼也。女将行，父礼之而俟迎者，盖母荐之，无祭事也。祭礼主妇设羹，教成之祭，更使季女者，成其妇礼也。季女不主鱼，鱼俎实男子设之，其粢盛盖以黍稷。",
        "文献id": "src001"
      },
      {
        "id": "n006",
        "anchor": "齐",
        "粒度": "字",
        "注释类型": "校勘",
        "内容": "齐本亦作「斋」，同侧皆反。",
        "文献id": "src001"
      }
    ]
  }
]