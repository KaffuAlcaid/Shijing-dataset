[
  {
    "id": "shijing_guofeng_shaonan_xinglu_s001",
    "今译": "",
    "校勘文": "厌浥行露，岂不夙夜，谓行多露！",
    "注释": [
      {
        "id": "n001",
        "anchor": "厌浥行露岂不夙夜谓行多露",
        "粒度": "句",
        "注释类型": "训诂",
        "内容": "兴也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "厌浥",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "厌浥，湿意也。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "行",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "行，道也。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "岂不",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "岂不，言有是也。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "夙",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "夙，早。",
        "文献id": "src001"
      },
      {
        "id": "n006",
        "anchor": "夜",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "夜，莫也。",
        "文献id": "src001"
      },
      {
        "id": "n007",
        "anchor": "厌浥行露岂不夙夜谓行多露",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "厌浥然湿，道中始有露，谓二月中嫁取时也。",
        "文献id": "src001"
      },
      {
        "id": "n008",
        "anchor": "厌浥行露岂不夙夜谓行多露",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "言我岂不知当早夜成昏礼与？谓道中之露大多，故不行耳。",
        "文献id": "src001"
      },
      {
        "id": "n009",
        "anchor": "厌浥行露岂不夙夜谓行多露",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "今强暴之男，以此多露之时，礼不足而强来，不度时之可否，故云然。",
        "文献id": "src001"
      },
      {
        "id": "n010",
        "anchor": "厌浥行露岂不夙夜谓行多露",
        "粒度": "句",
        "注释类型": "考证",
        "内容": "《周礼》仲春之月，令会男女之无夫家者，行事必以昏昕。",
        "文献id": "src001"
      },
      {
        "id": "n011",
        "anchor": "厌",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "厌，于叶反，徐于十反，又于立反，沈又于占反。",
        "文献id": "src001"
      },
      {
        "id": "n012",
        "anchor": "浥",
        "粒度": "字",
        "注释类型": "校勘",
        "内容": "浥，本又作「挹」，同于及反，又于胁反。",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 1,
      "篇": "行露"
    }
  },
  {
    "id": "shijing_guofeng_shaonan_xinglu_s002",
    "今译": "",
    "校勘文": "谁谓雀无角，何以穿我屋？",
    "注释": [],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 2,
      "篇": "行露"
    }
  },
  {
    "id": "shijing_guofeng_shaonan_xinglu_s003",
    "今译": "",
    "校勘文": "谁谓女无家，何以速我狱？",
    "注释": [
      {
        "id": "n001",
        "anchor": "谁谓女无家何以速我狱",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "不思物变而推其类，雀之穿屋，似有角者。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "速",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "速，召。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "狱",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "狱，埆也。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "女",
        "粒度": "字",
        "注释类型": "笺注",
        "内容": "女，汝。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "谁谓女无家何以速我狱",
        "粒度": "句",
        "注释类型": "笺注",
        "内容": "强暴之男，变异也。人皆谓雀之穿屋似有角，强暴之男，召我而狱，似有室家之道于我也。物有似而不同，雀之穿屋不以角，乃以咮，今强暴之男召我而狱，不以室家之道于我，乃以侵陵。物与事有似而非者，士师所当审也。",
        "文献id": "src001"
      },
      {
        "id": "n006",
        "anchor": "女",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "女音汝，下皆同。",
        "文献id": "src001"
      },
      {
        "id": "n007",
        "anchor": "狱",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "狱音玉。",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 3,
      "篇": "行露"
    }
  },
  {
    "id": "shijing_guofeng_shaonan_xinglu_s004",
    "今译": "",
    "校勘文": "虽速我狱，室家不足。",
    "注释": [
      {
        "id": "n001",
        "anchor": "虽速我狱室家不足",
        "粒度": "句",
        "注释类型": "考证",
        "内容": "昏礼纯帛不过五两。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "虽速我狱室家不足",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "币可备也。室家不足，谓媒妁之言不和，六礼之来强委之。",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 4,
      "篇": "行露"
    }
  },
  {
    "id": "shijing_guofeng_shaonan_xinglu_s005",
    "今译": "",
    "校勘文": "谁谓鼠无牙，何以穿我墉？",
    "注释": [],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 5,
      "篇": "行露"
    }
  },
  {
    "id": "shijing_guofeng_shaonan_xinglu_s006",
    "今译": "",
    "校勘文": "谁谓女无家，何以速我讼？",
    "注释": [
      {
        "id": "n001",
        "anchor": "谁谓女无家何以速我讼",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "视墙之穿，推其类可谓鼠有牙。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "讼",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "讼如字，徐取韵音才容反。",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 6,
      "篇": "行露"
    }
  },
  {
    "id": "shijing_guofeng_shaonan_xinglu_s007",
    "今译": "",
    "校勘文": "虽速我讼，亦不女从！",
    "注释": [
      {
        "id": "n001",
        "anchor": "虽速我讼亦不女从",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "不从，终不弃礼而随此强暴之男。",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 7,
      "篇": "行露"
    }
  }
]