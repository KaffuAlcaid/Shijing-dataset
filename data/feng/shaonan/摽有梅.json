      {
        "id": "n001",
        "anchor": "摽有梅其实三兮",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "在者三也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "摽有梅其实三兮",
        "粒度": "句",
        "注释类型": "笺注",
        "内容": "此夏乡晚，梅之隋落差多，在者馀三耳。",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
