[
  {
    "id": "shijing_guofeng_shaonan_biaoyoumei_s001",
    "今译": "",
    "校勘文": "摽有梅，其实七兮。",
    "注释": [
      {
        "id": "n001",
        "anchor": "摽有梅其实七兮",
        "粒度": "句",
        "注释类型": "训诂",
        "内容": "兴也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "摽",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "摽，落也。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "摽有梅其实七兮",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "盛极则隋落者，梅也。尚在树者七。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "摽有梅其实七兮",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "兴者，梅实尚馀七未落，喻始衰也。谓女二十，春盛而不嫁，至夏则衰。",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 1,
      "篇": "摽有梅"
    }
  },
  {
    "id": "shijing_guofeng_shaonan_biaoyoumei_s002",
    "今译": "",
    "校勘文": "求我庶士，迨其吉兮。",
    "注释": [
      {
        "id": "n001",
        "anchor": "吉",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "吉，善也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "我",
        "粒度": "字",
        "注释类型": "笺注",
        "内容": "我，我当嫁者。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "庶",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "庶，众。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "迨",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "迨，及也。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "求我庶士迨其吉兮",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "求女之当嫁者之众士，宜及其善时。善时谓年二十，虽夏未大衰。",
        "文献id": "src001"
      },
      {
        "id": "n006",
        "anchor": "迨",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "迨音待",
        "文献id": "src001"
      },
      {
        "id": "n007",
        "anchor": "迨",
        "粒度": "字",
        "注释类型": "考证",
        "内容": "《韩诗》云：「顾也。」",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 1,
      "篇": "摽有梅"
    }
  },
  {
    "id": "shijing_guofeng_shaonan_biaoyoumei_s003",
    "今译": "",
    "校勘文": "摽有梅，其实三兮。",
