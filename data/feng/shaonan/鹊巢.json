      }
    ]
  },
  {
    "id": "shijing_guofeng_shaonan_quechao_s005",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "鹊巢",
      "序号": 5
    },
    "校勘文": "维鹊有巢，维鸠盈之。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "盈",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "盈，满也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "盈",
        "粒度": "字",
        "注释类型": "笺注",
