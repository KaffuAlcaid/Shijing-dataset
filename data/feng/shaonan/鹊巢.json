[
  {
    "id": "shijing_guofeng_shaonan_quechao_s001",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "鹊巢",
      "序号": 1
    },
    "校勘文": "维鹊有巢，维鸠居之。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "维鹊有巢维鸠居之",
        "粒度": "句",
        "注释类型": "训诂",
        "内容": "兴也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "鸠",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "鸠，鳲鸠，秸鞠也。鳲鸠不自为巢，居鹊之成巢。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "维鹊有巢维鸠居之",
        "粒度": "句",
        "注释类型": "笺注",
        "内容": "笺云：鹊之作巢，冬至架之，至春乃成，犹国君积行累功，故以兴焉。兴者，鳲鸠因鹊成巢而居有之，而有均壹之德，犹国君夫人来嫁，居君子之室，德亦然。室，燕寝也。○秸，古八反，又音吉。《尔雅》作「鴶鞠」，音菊。《尔雅》作「鵴架」，音嫁。俗本或作「加功」。",
        "文献id": "src001"
      }
    ]
  },
  {
    "id": "shijing_guofeng_shaonan_quechao_s002",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "篇": "鹊巢",
      "序号": 2
    },
    "校勘文": "之子于归，百两御之。",
    "今译": "",
    "注音": "",
    "注释": [
      {
        "id": "n001",
        "anchor": "百两",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "百两，百乘也。诸侯之子嫁于诸侯，送御皆百乘。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "之子",
        "粒度": "词",
        "注释类型": "笺注",
        "内容": "笺云：之子，是子也。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "御",
        "粒度": "字",
        "注释类型": "笺注",
        "内容": "御，迎也。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "之子于归百两御之",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "是如鳲鸠之子，其往嫁也，家人送之，良人迎之，车皆百乘，象有百官之盛。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "御",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "○御，五嫁反，本亦作「讶」，又作「迓」，同。王肃鱼据反，云「侍也」。",
        "文献id": "src001"
      }
    ]
  },
  {
