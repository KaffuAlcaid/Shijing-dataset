        "anchor": "成",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "能成百两之礼也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "之子于归百两成之",
        "粒度": "句",
        "注释类型": "笺注",
        "内容": "笺云：是子有鳲鸠之德，宜配国君，故以百两之礼送迎成之。",
        "文献id": "src001"
      }
    ]
