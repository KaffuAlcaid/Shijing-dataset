[
  {
    "id": "shijing_guofeng_shaonan_yinqilei_s001",
    "今译": "",
    "校勘文": "殷其雷，在南山之阳。",
    "注释": [
      {
        "id": "n001",
        "anchor": "殷",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "殷，雷声也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "阳",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "山南曰阳。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "殷其雷在南山之阳",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "雷出地奋，震惊百里。山出云雨，以润天下。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "殷其雷在南山之阳",
        "粒度": "句",
        "注释类型": "笺注",
        "内容": "雷以喻号令于南山之阳，又喻其在外也。召南大夫以王命施号令于四方，犹雷殷殷然发声于山之阳。",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 1,
      "篇": "殷其雷"
    }
  },
  {
    "id": "shijing_guofeng_shaonan_yinqilei_s002",
    "今译": "",
    "校勘文": "何斯违斯，莫敢或遑。",
    "注释": [
      {
        "id": "n001",
        "anchor": "何",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "何此君子也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "斯",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "斯，此。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "违",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "违，去。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "遑",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "遑，暇也。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "何斯违斯莫敢或遑",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "何乎此君子，适居此，复去此，转行远，从事于王所命之方，无敢或闲暇时。闵其勤劳。",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 1,
      "篇": "殷其雷"
    }
  },
  {
    "id": "shijing_guofeng_shaonan_yinqilei_s003",
    "今译": "",
    "校勘文": "振振君子，归哉归哉！",
    "注释": [
      {
        "id": "n001",
        "anchor": "振振",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "振振，信厚也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "振振君子归哉归哉",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "大夫信厚之君子，为君使，功未成，归哉归哉！劝以为臣之义，未得归也。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "振",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "振音真。",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
