[
  {
    "id": "shijing_guofeng_shaonan_gantang_s001",
    "今译": "",
    "校勘文": "蔽芾甘棠，勿翦勿伐，召伯所茇。",
    "注释": [
      {
        "id": "n001",
        "anchor": "蔽芾",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "蔽芾，小貌。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "甘棠",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "甘棠，杜也。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "翦",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "翦，去。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "伐",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "伐，击也。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "茇",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "茇，草舍也。",
        "文献id": "src001"
      },
      {
        "id": "n006",
        "anchor": "蔽芾甘棠勿翦勿伐召伯所茇",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "召伯听男女之讼，不重烦劳百姓，止舍小棠之下而听断焉。国人被其德，说其化，思其人，敬其树。",
        "文献id": "src001"
      },
      {
        "id": "n007",
        "anchor": "蔽",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "蔽，必袂反，徐方四反，又方计反，沈又音必。",
        "文献id": "src001"
      },
      {
        "id": "n008",
        "anchor": "芾",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "芾，非贵反，徐方盖反。",
        "文献id": "src001"
      },
      {
        "id": "n009",
        "anchor": "翦",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "翦，子践反。",
        "文献id": "src001"
      },
      {
        "id": "n010",
        "anchor": "翦",
        "粒度": "字",
        "注释类型": "校勘",
        "内容": "《韩诗》作「笺」",
        "文献id": "src001"
      },
      {
        "id": "n011",
        "anchor": "茇",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "茇，蒲曷反，徐又扶盖反。",
        "文献id": "src001"
      },
      {
        "id": "n012",
        "anchor": "茇",
        "粒度": "字",
        "注释类型": "校勘",
        "内容": "《说文》作「𢇷」",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 1,
      "篇": "甘棠"
    }
  },
  {
    "id": "shijing_guofeng_shaonan_gantang_s002",
    "今译": "",
    "校勘文": "蔽芾甘棠，勿翦勿败，召伯所憩。",
    "注释": [
      {
        "id": "n001",
        "anchor": "憩",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "憩，息也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "败",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "败，必迈反，又如字。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "憩",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "憩，起例反，徐许罽反。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "憩",
        "粒度": "字",
        "注释类型": "校勘",
        "内容": "本又作「憩」",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 2,
      "篇": "甘棠"
    }
  },
  {
    "id": "shijing_guofeng_shaonan_gantang_s003",
    "今译": "",
    "校勘文": "蔽芾甘棠，勿翦勿拜，召伯所说。",
    "注释": [
      {
        "id": "n001",
        "anchor": "说",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "说，舍也。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "拜",
        "粒度": "字",
        "注释类型": "笺注",
        "内容": "拜之言拔也。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "说",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "同始锐反",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "说",
        "粒度": "字",
        "注释类型": "校勘",
        "内容": "本或作「税」，又作「脱」",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 3,
      "篇": "甘棠"
    }
  }
