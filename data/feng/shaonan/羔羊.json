[
  {
    "id": "shijing_guofeng_shaonan_gaoyang_s001",
    "今译": "",
    "校勘文": "羔羊之皮，素丝五紽。",
    "注释": [
      {
        "id": "n001",
        "anchor": "羔",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "小曰羔。",
        "文献id": "src001"
      },
      {
        "id": "n002",
        "anchor": "羊",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "大曰羊。",
        "文献id": "src001"
      },
      {
        "id": "n003",
        "anchor": "素",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "素，白也。",
        "文献id": "src001"
      },
      {
        "id": "n004",
        "anchor": "紽",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "紽，数也。",
        "文献id": "src001"
      },
      {
        "id": "n005",
        "anchor": "羔羊之皮素丝五紽",
        "粒度": "句",
        "注释类型": "句义",
        "内容": "古者素丝以英裘，不失其制，大夫羔裘以居。",
        "文献id": "src001"
      },
      {
        "id": "n006",
        "anchor": "紽",
        "粒度": "字",
        "注释类型": "校勘",
        "内容": "它，本又作「他」，同徒何反。「它数也」，本或作「紽数」，所具反，后不音者同。",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 1,
      "篇": "羔羊"
    }
  },
  {
    "id": "shijing_guofeng_shaonan_gaoyang_s002",
    "今译": "",
    "校勘文": "退食自公，委蛇委蛇。",
    "注释": [
      {
        "id": "n007",
        "anchor": "公",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "公，公门也。",
        "文献id": "src001"
      },
      {
        "id": "n008",
        "anchor": "委蛇",
        "粒度": "词",
        "注释类型": "训诂",
        "内容": "委蛇，行可从迹也。",
        "文献id": "src001"
      },
      {
        "id": "n009",
        "anchor": "退食",
        "粒度": "词",
        "注释类型": "笺注",
        "内容": "退食，谓减膳也。",
        "文献id": "src001"
      },
      {
        "id": "n010",
        "anchor": "自",
        "粒度": "字",
        "注释类型": "笺注",
        "内容": "自，从也。",
        "文献id": "src001"
      },
      {
        "id": "n011",
        "anchor": "委蛇",
        "粒度": "词",
        "注释类型": "笺注",
        "内容": "委蛇，委曲自得之貌，节俭而顺，心志定，故可自得也。",
        "文献id": "src001"
      },
      {
        "id": "n012",
        "anchor": "委",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "委，于危反。",
        "文献id": "src001"
      },
      {
        "id": "n013",
        "anchor": "蛇",
        "粒度": "字",
        "注释类型": "校勘",
        "内容": "蛇，又作「蛇」，同音移。",
        "文献id": "src001"
      },
      {
        "id": "n014",
        "anchor": "委蛇",
        "粒度": "词",
        "注释类型": "音韵",
        "内容": "读此两句，当云「委蛇委蛇」，沈读作「委委蛇蛇」。",
        "文献id": "src001"
      },
      {
        "id": "n015",
        "anchor": "委蛇",
        "粒度": "词",
        "注释类型": "校勘",
        "内容": "《韩诗》作「逶迄」，云公正貌。",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 1,
      "篇": "羔羊"
    }
  },
  {
    "id": "shijing_guofeng_shaonan_gaoyang_s003",
    "今译": "",
    "校勘文": "羔羊之革，素丝五緎。",
    "注释": [
      {
        "id": "n016",
        "anchor": "革",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "革犹皮也。",
        "文献id": "src001"
      },
      {
        "id": "n017",
        "anchor": "緎",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "緎，缝也。",
        "文献id": "src001"
      },
      {
        "id": "n018",
        "anchor": "緎",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "緎，徐音域，又于域反。",
        "文献id": "src001"
      },
      {
        "id": "n019",
        "anchor": "緎",
        "粒度": "字",
        "注释类型": "考证",
        "内容": "孙炎云：「緎缝之界域。」「緎，缝」，《尔雅》云「緎，羔裘之缝也」，音符用反。",
        "文献id": "src001"
      },
      {
        "id": "n020",
        "anchor": "緎",
        "粒度": "字",
        "注释类型": "校勘",
        "内容": "一本作「緎犹缝也」，则当音符龙反。",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 1,
      "篇": "羔羊"
    }
  },
  {
    "id": "shijing_guofeng_shaonan_gaoyang_s004",
    "今译": "",
    "校勘文": "委蛇委蛇，自公退食。",
    "注释": [
      {
        "id": "n021",
        "anchor": "委蛇委蛇自公退食",
        "粒度": "句",
        "注释类型": "训诂",
        "内容": "自公退食，犹退食自公。",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 1,
      "篇": "羔羊"
    }
  },
  {
    "id": "shijing_guofeng_shaonan_gaoyang_s005",
    "今译": "",
    "校勘文": "羔羊之缝，素丝五裛。",
    "注释": [
      {
        "id": "n022",
        "anchor": "缝",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "缝，言缝杀之，大小得其制。",
        "文献id": "src001"
      },
      {
        "id": "n023",
        "anchor": "裛",
        "粒度": "字",
        "注释类型": "训诂",
        "内容": "裛，数也。",
        "文献id": "src001"
      },
      {
        "id": "n024",
        "anchor": "缝",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "缝，符龙反，注同。注「缝杀之」字又音符用反。",
        "文献id": "src001"
      },
      {
        "id": "n025",
        "anchor": "裛",
        "粒度": "字",
        "注释类型": "音韵",
        "内容": "裛，子公反。",
        "文献id": "src001"
      }
    ],
    "注音": "",
    "篇目": {
      "书": "诗经",
      "卷": "国风",
      "序号": 1,
      "篇": "羔羊"
    }
  },
